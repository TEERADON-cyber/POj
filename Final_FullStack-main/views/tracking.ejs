<%- include('layout-top') %>

<h2>Parcel Details</h2>
<p><strong>Tracking:</strong> <%= parcel.tracking_number %></p>
<p><strong>Receiver:</strong> <%= parcel.receiver_name %> (<%= parcel.receiver_phone %>)</p>
<p><strong>Address:</strong> <%= parcel.receiver_address %></p>
<p><strong>Weight:</strong> <%= parcel.weight %> kg</p>
<p><strong>Shipping Cost:</strong> <%= parcel.shipping_cost %></p>
<p><strong>Status:</strong> <%= parcel.status %></p>

<h3>Payment</h3>
<% if (payment) { %>
  <p>Amount: <%= payment.amount %></p>
  <p>Status: <%= payment.payment_status %></p>
<% } else { %>
  <p>No payment recorded.</p>
  <% if (parcel.status === 'Pending') { %>
    <p><a class="btn" href="/parcels/<%= parcel.parcel_id %>/pay">Pay Now</a></p>
  <% } %>
<% } %>
<% if (parcel.status === 'Pending' || parcel.status === 'Paid') { %>
  <form action="/parcels/<%= parcel.parcel_id %>/cancel" method="post">
    <button type="submit" class="btn secondary" onclick="return confirm('ยืนยันยกเลิกพัสดุนี้?');">Cancel Parcel</button>
  </form>
<% } %>

<p><a href="<%= userRole === 'admin' ? '/admin/dashboard' : '/parcels/dashboard' %>">Back to Dashboard</a></p>

<%- include('layout-bottom') %>

